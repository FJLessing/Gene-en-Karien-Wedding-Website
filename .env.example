# Gene + Karien wedding website — environment variables.
# Copy to `.env` for local development. On Cloud Run set these as service env vars.
# Nuxt maps NUXT_-prefixed vars onto runtimeConfig automatically at runtime.

# ── Access gate (Story 1) ─────────────────────────────────────────────────────
# Password checked server-side when no invite URL param is present.
NUXT_SITE_PASSWORD=

# URL param name that grants access via a shared link, e.g. ?invite=anything
NUXT_PUBLIC_ACCESS_PARAM=invite

# ── Google Sheets (RSVPs — Story 3) ───────────────────────────────────────────
NUXT_GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Paste the private key with literal \n escapes; the server converts them.
NUXT_GOOGLE_PRIVATE_KEY=
NUXT_GOOGLE_SHEET_ID=

# ── GCP Cloud Storage (photo uploads — Story 3/4) ─────────────────────────────
NUXT_GCS_PROJECT_ID=
NUXT_GCS_BUCKET=

# ── Photo gallery (Story 4) ───────────────────────────────────────────────────
# Moderated gallery source (Drive/GCS folder) shown once the gallery unlocks.
NUXT_PUBLIC_GALLERY_FOLDER_URL=
# ISO date the gallery opens, e.g. 2026-10-09
NUXT_PUBLIC_GALLERY_UNLOCK_DATE=
